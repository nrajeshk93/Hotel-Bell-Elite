# Copy to .env and adjust. Required for HTTPS / Android WebView session cookies.
FLASK_ENV=production
SESSION_COOKIE_SECURE=1

# Set a long random value in production (do not use the app.py default).
SECRET_KEY=change-me-to-a-long-random-string

# WhatsApp Cloud API (shared WABA with Neeraj Textile; use HBE phone number ID)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v21.0
WHATSAPP_WABA_ID=1668789490989068
WHATSAPP_PHONE_NUMBER_ID=1241737459022736
WHATSAPP_VERIFY_TOKEN=change-me-whatsapp-verify-token
WHATSAPP_INDENT_APPROVAL_TEMPLATE=indent_approval_v2
WHATSAPP_INDENT_APPROVAL_TEMPLATE_LANGUAGE=en
WHATSAPP_INDENT_APPROVER_NAME=Neeraj
# Comma-separated E.164 / local numbers, e.g. +919611232344,9876543210
WHATSAPP_INDENT_APPROVER_NUMBERS=
# Max successful indent-approval WhatsApp sends per rolling 24 hours (default 10)
WHATSAPP_INDENT_DAILY_CAP=10
# Safety: set to 1 to block all live Meta HTTP (messages + media upload)
# WHATSAPP_DRY_RUN=1
# Unit tests with Flask TESTING already block live sends unless this is 1
# WHATSAPP_ALLOW_IN_TESTS=0
# Host that receives Meta webhooks. Live Send for Approval from any other host
# is blocked so tokens are not written to a DB the webhook cannot see.
WHATSAPP_INDENT_PUBLIC_HOST=belleliteaccounts.com
